{
  "openapi": "3.1.0",
  "info": {
    "title": "smplkit Config API",
    "description": "Configuration management API for smplkit.",
    "version": "0.1.0"
  },
  "paths": {
    "/api/v1/configs": {
      "post": {
        "tags": [
          "Configs"
        ],
        "summary": "Create Config",
        "operationId": "create_config",
        "security": [
          {
            "HTTPBearer": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Response_Config_"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Successful Response",
            "content": {
              "application/vnd.api+json": {
                "schema": {
                  "$ref": "#/components/schemas/ConfigResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/vnd.api+json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      },
      "get": {
        "tags": [
          "Configs"
        ],
        "summary": "List Configs",
        "operationId": "list_configs",
        "security": [
          {
            "HTTPBearer": []
          }
        ],
        "parameters": [
          {
            "name": "filter[parent]",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Filter[Parent]"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/vnd.api+json": {
                "schema": {
                  "$ref": "#/components/schemas/ConfigListResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/vnd.api+json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/configs/{id}": {
      "get": {
        "tags": [
          "Configs"
        ],
        "summary": "Get Config",
        "operationId": "get_config",
        "security": [
          {
            "HTTPBearer": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/vnd.api+json": {
                "schema": {
                  "$ref": "#/components/schemas/ConfigResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/vnd.api+json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": [
          "Configs"
        ],
        "summary": "Update Config",
        "operationId": "update_config",
        "security": [
          {
            "HTTPBearer": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Id"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Response_Config_"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/vnd.api+json": {
                "schema": {
                  "$ref": "#/components/schemas/ConfigResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/vnd.api+json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "Configs"
        ],
        "summary": "Delete Config",
        "operationId": "delete_config",
        "security": [
          {
            "HTTPBearer": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Id"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Successful Response"
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/vnd.api+json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/usage": {
      "get": {
        "tags": [
          "Usage"
        ],
        "summary": "List Config Usage",
        "description": "Return current resource usage counts for the authenticated account.",
        "operationId": "list_config_usage",
        "security": [
          {
            "HTTPBearer": []
          }
        ],
        "parameters": [
          {
            "name": "filter[period]",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Filter[Period]"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Current usage for the authenticated account",
            "content": {
              "application/vnd.api+json": {
                "schema": {}
              }
            }
          },
          "400": {
            "description": "Missing or invalid filter[period] parameter"
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/vnd.api+json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Config": {
        "properties": {
          "name": {
            "type": "string",
            "maxLength": 255,
            "title": "Name"
          },
          "description": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 1000
              },
              {
                "type": "null"
              }
            ],
            "title": "Description"
          },
          "parent": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Parent"
          },
          "items": {
            "anyOf": [
              {
                "additionalProperties": {
                  "$ref": "#/components/schemas/ConfigItemDefinition"
                },
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Items"
          },
          "environments": {
            "anyOf": [
              {
                "additionalProperties": {
                  "$ref": "#/components/schemas/EnvironmentOverride"
                },
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Environments"
          },
          "created_at": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "Created At",
            "readOnly": true
          },
          "updated_at": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "Updated At",
            "readOnly": true
          }
        },
        "type": "object",
        "required": [
          "name"
        ],
        "title": "Config",
        "example": {
          "created_at": "2026-03-27T10:00:00Z",
          "description": "Database configuration",
          "environments": {
            "prod": {
              "values": {
                "host": {
                  "value": "db-prod.internal"
                },
                "pool_size": {
                  "value": 20
                }
              }
            }
          },
          "items": {
            "host": {
              "description": "Primary database hostname",
              "type": "STRING",
              "value": "db.internal"
            },
            "pool_size": {
              "description": "Connection pool size",
              "type": "NUMBER",
              "value": 10
            }
          },
          "name": "Database",
          "updated_at": "2026-03-27T10:00:00Z"
        }
      },
      "ConfigItemDefinition": {
        "properties": {
          "value": {
            "title": "Value"
          },
          "type": {
            "anyOf": [
              {
                "type": "string",
                "enum": [
                  "STRING",
                  "NUMBER",
                  "BOOLEAN",
                  "JSON"
                ]
              },
              {
                "type": "null"
              }
            ],
            "title": "Type"
          },
          "description": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 1000
              },
              {
                "type": "null"
              }
            ],
            "title": "Description"
          }
        },
        "type": "object",
        "required": [
          "value"
        ],
        "title": "ConfigItemDefinition",
        "description": "Schema for a single config item."
      },
      "ConfigItemOverride": {
        "properties": {
          "value": {
            "title": "Value"
          }
        },
        "type": "object",
        "required": [
          "value"
        ],
        "title": "ConfigItemOverride",
        "description": "Schema for an environment override \u2014 value only, no type/description."
      },
      "ConfigListResponse": {
        "properties": {
          "data": {
            "items": {
              "$ref": "#/components/schemas/ConfigResource"
            },
            "type": "array",
            "title": "Data"
          }
        },
        "type": "object",
        "required": [
          "data"
        ],
        "title": "ConfigListResponse"
      },
      "ConfigResource": {
        "properties": {
          "id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Id"
          },
          "type": {
            "type": "string",
            "const": "config",
            "title": "Type"
          },
          "attributes": {
            "$ref": "#/components/schemas/Config"
          }
        },
        "type": "object",
        "required": [
          "type",
          "attributes"
        ],
        "title": "ConfigResource",
        "example": {
          "attributes": {
            "created_at": "2026-03-27T10:00:00Z",
            "description": "Database configuration",
            "environments": {
              "prod": {
                "values": {
                  "host": {
                    "value": "db-prod.internal"
                  }
                }
              }
            },
            "items": {
              "host": {
                "description": "Primary database hostname",
                "type": "STRING",
                "value": "db.internal"
              }
            },
            "name": "Database",
            "parent": "common",
            "updated_at": "2026-03-27T10:00:00Z"
          },
          "id": "database",
          "type": "config"
        }
      },
      "ConfigResponse": {
        "properties": {
          "data": {
            "$ref": "#/components/schemas/ConfigResource"
          }
        },
        "type": "object",
        "required": [
          "data"
        ],
        "title": "ConfigResponse"
      },
      "EnvironmentOverride": {
        "properties": {
          "values": {
            "anyOf": [
              {
                "additionalProperties": {
                  "$ref": "#/components/schemas/ConfigItemOverride"
                },
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Values"
          }
        },
        "type": "object",
        "title": "EnvironmentOverride",
        "description": "Schema for per-environment overrides."
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "Resource_Config_": {
        "properties": {
          "id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Id"
          },
          "type": {
            "type": "string",
            "title": "Type",
            "default": ""
          },
          "attributes": {
            "$ref": "#/components/schemas/Config"
          }
        },
        "type": "object",
        "required": [
          "attributes"
        ],
        "title": "Resource[Config]"
      },
      "Response_Config_": {
        "properties": {
          "data": {
            "$ref": "#/components/schemas/Resource_Config_"
          }
        },
        "type": "object",
        "required": [
          "data"
        ],
        "title": "Response[Config]"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    },
    "securitySchemes": {
      "HTTPBearer": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  },
  "tags": [
    {
      "name": "Configs"
    }
  ]
}
