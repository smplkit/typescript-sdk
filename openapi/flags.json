        "example": {
          "created_at": "2026-03-27T10:00:00Z",
          "default": false,
          "description": "Enable dark mode for the application UI",
          "environments": {
            "production": {
              "default": false,
              "enabled": true,
              "rules": [
                {
                  "description": "Beta users get dark mode",
                  "logic": {
                    "attribute": "beta",
                    "op": "eq",
                    "value": true
                  },
                  "value": true
                }
              ]
            },
            "staging": {
              "default": true,
              "enabled": true,
              "rules": []
            }
          },
          "key": "dark_mode",
